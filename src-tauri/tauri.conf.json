{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Compressor",
  "version": "0.3.3",
  "identifier": "com.anttijakunaho.imagecompressor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Image Compressor",
        "width": 1080,
        "height": 720,
        "minWidth": 840,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: blob: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Compress images to a target file size.",
    "longDescription": "Compress and resize images to hit a target file-size cap (KB/MB), single or batch. Fast, offline, pure-Rust engine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
